# Build the environments fresh from pixi.lock inside the image — never
# ship the host's solved envs (they're huge and host-specific).
.pixi/

# VCS / CI / editor cruft
.git/
.github/
.gitignore
.pre-commit-config.yaml

# Docs site build output and local caches
site/
**/__pycache__/
*.pyc

# Keep build metadata out of the image layers. (docker-entrypoint.sh is
# intentionally NOT ignored — the runtime stage COPYs it explicitly.)
Dockerfile
.dockerignore
liulab-runtime.def
