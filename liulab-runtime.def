# Singularity / Apptainer definition for liulab-runtime.
#
# Each image holds ONE environment. Bootstraps from that env's Docker image
# (built by the repo's Dockerfile), so the Dockerfile stays the single source
# of truth for what's in the container. Pick the env with `--build-arg ENV=...`.
#
# Build:
#   # pick the environment (align-rna, align-dna, ml, ml-gpu, ...)
#   singularity build --build-arg ENV=align-rna liulab-runtime_align-rna.sif liulab-runtime.def
#   # or pull the published image directly, no def file needed:
#   singularity pull docker://ghcr.io/liuhlab/liulab-runtime:align-rna
#
# Note: the workspace has no linux-aarch64 platform, so the underlying image
# is amd64-only. The `ml-gpu` image needs a GPU host — run it with `--nv`.
Bootstrap: docker
From: ghcr.io/liuhlab/liulab-runtime:{{ ENV }}

%labels
    Maintainer Liu Lab
    Description Liu Lab pixi environment (one env per image).

%help
    This image contains a single liulab-runtime environment (baked in as
    LIULAB_ENV). Run commands in it via pixi:

      singularity run  liulab-runtime_<env>.sif <cmd>       # run <cmd> in this image's env
      singularity run  liulab-runtime_align-rna.sif STAR --version
      singularity shell liulab-runtime_ml.sif               # then: pixi shell -e "$LIULAB_ENV"

    GPU images (ml-gpu) require the host driver — add --nv:
      singularity run --nv liulab-runtime_ml-gpu.sif python -c "import torch; print(torch.cuda.is_available())"

%environment
    export LIULAB_ENV="${LIULAB_ENV:-default}"

%runscript
    cd /app
    exec pixi run -e "${LIULAB_ENV:-default}" "$@"
